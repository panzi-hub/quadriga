# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# After installing requirements, also install Playwright browsers:
#   pip install -r requirements.txt
#   python -m playwright install chromium

# ============================================================================
# API Configuration (必需)
# ============================================================================

OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
HARNESS_MODEL=gpt-4o

# ============================================================================
# Workspace
# ============================================================================

# 工作空间目录，Agent 在此目录内操作
HARNESS_WORKSPACE=./workspace

# 扁平化 workspace（用于 benchmarks，多容器同时运行时避免目录冲突）
# HARNESS_FLAT_WORKSPACE=1

# ============================================================================
# Context Tuning (上下文阈值)
# ============================================================================

# 触发上下文压缩的 token 数量
# 达到此值时，旧消息被摘要压缩
COMPRESS_THRESHOLD=50000

# 触发上下文重置的 token 数量
# 达到此值时，写 checkpoint 到 progress.md，重置为空消息列表
RESET_THRESHOLD=100000

# ============================================================================
# Harness Tuning (Harness 轮次配置)
# ============================================================================

# 最大 Build → Evaluate 循环次数
MAX_HARNESS_ROUNDS=5

# 通过阈值（0-10），评估分数 >= 此值则任务完成
PASS_THRESHOLD=7.0

# 单个 Agent 的最大工具调用次数
MAX_AGENT_ITERATIONS=500

# 允许并行工具调用（仅对能正确处理并发的模型启用）
ENABLE_PARALLEL_TOOL_CALLS=0

# API 错误后最大重试次数
MAX_TOOL_ERRORS=5

# ============================================================================
# Time Budget (时间预算，用于 TimeBudgetMiddleware)
# ============================================================================

# 任务总时间预算（秒），会覆盖 Profile 中的默认值
# TASK_BUDGET_SECONDS=1800

# ============================================================================
# Profile Overrides (Profile 配置覆盖)
# ============================================================================

# App Builder Profile
# PROFILE_APP_BUILDER_MAX_ROUNDS=5
# PROFILE_APP_BUILDER_PASS_THRESHOLD=7.0

# Terminal Profile
# PROFILE_TERMINAL_TASK_BUDGET=1800
# PROFILE_TERMINAL_PASS_THRESHOLD=7.0
